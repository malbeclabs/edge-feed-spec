# Copy to .env and edit for your feed, then `docker compose up --build`.

# --- MBO feed under test ---
# The multicast group and the three MBO ports the publisher emits on.
# Example (Hyperliquid mainnet2): group 233.84.178.15, ports 10201/10202/10203.
DZ_MBO_MULTICAST_GROUP=239.10.10.20
DZ_MBO_MKTDATA_PORT=10201
DZ_MBO_REFDATA_PORT=10202
DZ_MBO_SNAPSHOT_PORT=10203

# Interface to join the multicast group on (the DoubleZero tunnel iface).
DZ_INTERFACE=doublezero1

# --- Ports ---
# dz-conformance /metrics bind (must match the target in prometheus/prometheus.yml).
CONFORMANCE_METRICS_PORT=9094
# Prometheus own listen port (must match the datasource url's port, 9095).
PROMETHEUS_PORT=9095
# Grafana UI port on the host.
GRAFANA_HOST_PORT=3000

# --- Grafana ---
GF_ADMIN_PASSWORD=admin
