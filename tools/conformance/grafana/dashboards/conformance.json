    {
      "type": "table",
      "title": "Per-rule conformance (current window)",
      "id": 63,
      "gridPos": {
        "x": 0,
        "y": 55,
        "w": 24,
        "h": 14
      },
      "datasource": {
        "uid": "prometheus-conformance",
        "type": "prometheus"
      },
      "description": "One row per rule applicable to this feed (from dz_conformance_rule_info). violations / unverifiable are increases over the dashboard time range; 0 violations = conforming. Click a rule to open its spec section.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "violations"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "unverifiable"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "blue",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rule_id"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "open spec section",
                    "url": "${__data.fields.spec_url}",
                    "targetBlank": true
                  }
                ]
              },
              {
                "id": "custom.width",
                "value": 330
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "severity"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "spec_url"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": false
        },
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "violations",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "uid": "prometheus-conformance",
            "type": "prometheus"
          },
          "expr": "dz_conformance_rule_info",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": {
            "uid": "prometheus-conformance",
            "type": "prometheus"
          },
          "expr": "sum by (rule_id) (increase(dz_conformance_violations_total[$__range]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": {
            "uid": "prometheus-conformance",
            "type": "prometheus"
          },
          "expr": "sum by (rule_id) (increase(dz_conformance_unverifiable_total[$__range]))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "rule_id",
            "mode": "outer"
          }
